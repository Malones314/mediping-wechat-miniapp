.page {
  padding: 32rpx 32rpx 60rpx;
}

.empty {
  height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  opacity: 0.8;
}

.emptyIcon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 900;
  color: #94a3b8;
}

.emptyText {
  color: #64748b;
}

.head {
  padding: 30rpx 0 20rpx;
}

.badge {
  display: inline-flex;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  font-weight: 700;
  border: 1px solid rgba(15, 23, 42, 0.06);
}

.badgeOn {
  background: rgba(20, 184, 166, 0.10);
  color: #0f766e;
  border-color: rgba(20, 184, 166, 0.20);
}

.badgeOff {
  background: #f1f5f9;
  color: #64748b;
}

.name {
  margin-top: 18rpx;
  font-size: 56rpx;
  font-weight: 900;
  color: #0f172a;
}

.sub {
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
}

.cards {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.infoCard {
  padding: 26rpx 26rpx;
  border-radius: 28rpx;
}

.infoTitle {
  font-weight: 800;
  color: #334155;
  margin-bottom: 16rpx;
}

.infoRow {
  color: #64748b;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.strong {
  color: #0f172a;
  font-weight: 700;
}

.timesGrid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.timeCell {
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  border: 1px solid rgba(15, 23, 42, 0.06);
  color: #334155;
  font-weight: 700;
  min-width: 150rpx;
  text-align: center;
}

.timeText {
  font-weight: 800;
}

.noteText {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  line-height: 30rpx;
  text-align: left;
}

.bottom {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
